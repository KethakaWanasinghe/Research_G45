{
  "metadata": {
    "version": "2.0",
    "description": "HRV-Driven Music Therapy Database for Exam Stress Reduction",
    "research_basis": "Bernardi et al. (2006); Trappe (2010); Thoma et al. (2013); Zhang et al. (2026)",
    "bpm_logic": {
      "high_stress": {
        "rmssd_threshold": "< 20ms",
        "lf_hf_threshold": "> 3.0",
        "bpm_range": [55, 65],
        "target": "Maximum parasympathetic activation - reduce acute distress"
      },
      "moderate_stress": {
        "rmssd_threshold": "20-40ms",
        "lf_hf_threshold": "1.5-3.0",
        "bpm_range": [65, 80],
        "target": "Eustress maintenance - keep alertness without panic"
      },
      "low_stress": {
        "rmssd_threshold": "> 40ms",
        "lf_hf_threshold": "< 1.5",
        "bpm_range": null,
        "target": "No intervention - preserve optimal cognitive arousal"
      }
    }
  },

